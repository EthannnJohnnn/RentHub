<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PropertyListController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Label text="|" styleClass="nav-title" opacity="0.3"/>
            <Label text="Browse Properties" styleClass="nav-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Dashboard" onAction="#handleBackToDashboard" styleClass="secondary-button"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="24">
            <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

            <!-- Header + Search Row -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Available Properties" styleClass="screen-title"/>
                    <Label fx:id="resultCountLabel" text="Showing all listings"
                           styleClass="subtitle"/>
                </VBox>
                <TextField fx:id="searchField"
                           promptText="Search by name or address..."
                           styleClass="input-field"
                           prefWidth="280"/>
            </HBox>

            <!-- Properties Table -->
            <TableView fx:id="propertyTable" styleClass="table-view"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Property Name" prefWidth="220"/>
                    <TableColumn fx:id="addressColumn" text="Address" prefWidth="240"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="240"/>
                    <TableColumn fx:id="viewColumn" text="" prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No properties match your search." styleClass="subtitle"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

</BorderPane>