<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginController"
      alignment="CENTER" spacing="16"
      styleClass="form-container"
      stylesheets="@../styles/styles.css">

    <padding><Insets top="60" right="80" bottom="60" left="80"/></padding>

    <Label text="Renta" styleClass="app-title"/>
    <Label text="Sign in to your account" styleClass="subtitle"/>

    <TextField fx:id="usernameField" promptText="Username" styleClass="input-field" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field" maxWidth="320"/>

    <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true" maxWidth="320"/>

    <Button text="Login" onAction="#handleLogin" styleClass="primary-button" maxWidth="320"/>

    <Hyperlink text="Don't have an account? Register" onAction="#goToRegister"/>
</VBox>