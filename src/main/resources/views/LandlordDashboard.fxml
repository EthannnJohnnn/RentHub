<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.LandlordDashboardController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, Landlord" styleClass="nav-title"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

            <!-- Header Row -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Landlord Dashboard" styleClass="screen-title"/>
                    <Label text="Manage your properties, rooms, and booking requests."
                           styleClass="subtitle"/>
                </VBox>
                <Button text="Booking Requests"
                        onAction="#handleBookingRequests"
                        styleClass="secondary-button"/>
                <Button text="Manage Listings"
                        onAction="#handleManageListings"
                        styleClass="primary-button"/>
                <Button text="+ Add Property"
                        onAction="#handleAddProperty"
                        styleClass="secondary-button"/>
            </HBox>

            <!-- My Listings Preview -->
            <VBox styleClass="card" spacing="16">
                <HBox alignment="CENTER_LEFT">
                    <Label text="MY LISTINGS PREVIEW" styleClass="label-text"
                           HBox.hgrow="ALWAYS"/>
                    <Label text="Click Manage Listings for full controls"
                           styleClass="subtitle"/>
                </HBox>
                <ListView fx:id="listingsView"
                          prefHeight="280"
                          styleClass="list-view"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>