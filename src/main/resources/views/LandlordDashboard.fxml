<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.LandlordDashboardController"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_RIGHT" spacing="12">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Label fx:id="welcomeLabel" text="Welcome, Landlord" styleClass="nav-title" HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Property" onAction="#handleAddProperty" styleClass="primary-button"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT — placeholder until @alalim wires in listing management -->
    <center>
        <VBox alignment="CENTER" spacing="16">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            <Label text="My Listings" styleClass="section-title"/>
            <ListView fx:id="listingsView" prefHeight="400" prefWidth="640" styleClass="list-view"/>
        </VBox>
    </center>
</BorderPane>