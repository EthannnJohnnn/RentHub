<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MyBookingsController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Label text="|" styleClass="nav-title" opacity="0.3"/>
            <Label text="My Bookings" styleClass="nav-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Dashboard" onAction="#handleBackToDashboard"
                    styleClass="secondary-button"/>
            <Button text="Logout" onAction="#handleLogout"
                    styleClass="danger-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="24">
            <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

            <!-- Page Header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="My Bookings" styleClass="screen-title"/>
                    <Label fx:id="bookingCountLabel" text="0 bookings"
                           styleClass="subtitle"/>
                </VBox>
            </HBox>

            <!-- Info card -->
            <VBox styleClass="card-flat" spacing="8">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Status Guide:" styleClass="label-text"/>
                    <Label text="PENDING — waiting for landlord review"
                           styleClass="subtitle"/>
                    <Label text="  |  " styleClass="subtitle"/>
                    <Label text="APPROVED — booking confirmed"
                           styleClass="subtitle"/>
                    <Label text="  |  " styleClass="subtitle"/>
                    <Label text="REJECTED — booking declined"
                           styleClass="subtitle"/>
                </HBox>
            </VBox>

            <!-- Bookings Table -->
            <TableView fx:id="bookingsTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="propertyColumn" text="Property" prefWidth="200"/>
                    <TableColumn fx:id="roomColumn" text="Room" prefWidth="100"/>
                    <TableColumn fx:id="priceColumn" text="Price / Month" prefWidth="140"/>
                    <TableColumn fx:id="dateColumn" text="Booking Date" prefWidth="160"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                </columns>
                <placeholder>
                    <Label text="You have no bookings yet. Browse properties to make a booking."
                           styleClass="subtitle"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

</BorderPane>