<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ReviewController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Label text="|" styleClass="nav-title" opacity="0.3"/>
            <Label fx:id="navPropertyName" text="Reviews" styleClass="nav-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Property" onAction="#handleBack" styleClass="secondary-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24">
                <padding><Insets top="32" right="40" bottom="40" left="40"/></padding>

                <!-- Header -->
                <VBox spacing="6">
                    <Label fx:id="propertyNameLabel" text="Property Reviews"
                           styleClass="screen-title"/>
                    <Label fx:id="reviewCountLabel" text="0 reviews"
                           styleClass="subtitle"/>
                </VBox>

                <!-- Existing Reviews -->
                <VBox styleClass="card" spacing="12">
                    <Label text="ALL REVIEWS" styleClass="label-text"/>
                    <ListView fx:id="reviewListView" styleClass="list-view" prefHeight="260"/>
                </VBox>

                <!-- Submit New Review -->
                <VBox styleClass="card-flat" spacing="16">
                    <Label text="Write a Review" styleClass="card-title"/>

                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox spacing="6">
                            <Label text="Rating *" styleClass="label-text"/>
                            <ComboBox fx:id="ratingComboBox"
                                      promptText="Select 1–5"
                                      styleClass="input-field"
                                      prefWidth="180"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Your Review *" styleClass="label-text"/>
                        <TextArea fx:id="commentArea"
                                  promptText="Tell others about your experience..."
                                  styleClass="text-area-field"
                                  prefHeight="100" wrapText="true"/>
                    </VBox>

                    <Label fx:id="errorLabel" text="" styleClass="error-label" wrapText="true"/>
                    <Label fx:id="successLabel" text="" styleClass="success-label" wrapText="true"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Submit Review" onAction="#handleSubmitReview"
                                styleClass="primary-button"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>