<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.BookingController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Label text="|" styleClass="nav-title" opacity="0.3"/>
            <Label text="Book a Room" styleClass="nav-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Property" onAction="#handleCancel" styleClass="secondary-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox alignment="TOP_CENTER" spacing="24">
                <padding><Insets top="40" right="200" bottom="40" left="200"/></padding>

                <!-- Header -->
                <VBox spacing="6">
                    <Label text="Complete Your Booking" styleClass="screen-title"/>
                    <Label text="Review the room details and confirm your booking request."
                           styleClass="subtitle"/>
                </VBox>

                <!-- Room Summary Card -->
                <VBox styleClass="card" spacing="16">
                    <Label text="ROOM SUMMARY" styleClass="label-text"/>
                    <HBox spacing="40">
                        <VBox spacing="6">
                            <Label text="Property" styleClass="detail-label"/>
                            <Label fx:id="propertyNameLabel" text="—" styleClass="detail-value"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Room" styleClass="detail-label"/>
                            <Label fx:id="roomNumberLabel" text="—" styleClass="detail-value"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Capacity" styleClass="detail-label"/>
                            <Label fx:id="capacityLabel" text="—" styleClass="detail-value"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Price / Month" styleClass="detail-label"/>
                            <Label fx:id="priceLabel" text="—" styleClass="detail-value"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Booking Form Card -->
                <VBox styleClass="card" spacing="20">
                    <Label text="Booking Details" styleClass="card-title"/>

                    <VBox spacing="6">
                        <Label text="Booking Date *" styleClass="label-text"/>
                        <DatePicker fx:id="bookingDatePicker"
                                    promptText="Select date"
                                    styleClass="input-field"
                                    maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="errorLabel" text="" styleClass="error-label" wrapText="true"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Cancel" onAction="#handleCancel" styleClass="secondary-button"/>
                        <Button text="Confirm Booking" onAction="#handleSubmit"
                                styleClass="primary-button"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>