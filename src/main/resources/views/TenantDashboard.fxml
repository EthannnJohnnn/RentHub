<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.TenantDashboardController"
            styleClass="page-container"
            stylesheets="@../styles/styles.css">

    <!-- TOP NAV -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Renta" styleClass="nav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, Tenant" styleClass="nav-title"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="24">
            <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

            <!-- Header Row -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Tenant Dashboard" styleClass="screen-title"/>
                    <Label text="Search and browse available properties below."
                           styleClass="subtitle"/>
                </VBox>
                <!-- THE MISSING BUTTON -->
                <Button text="Browse All Properties"
                        onAction="#handleBrowseProperties"
                        styleClass="primary-button"/>
            </HBox>

            <!-- Quick Search Card -->
            <VBox styleClass="card" spacing="16">
                <Label text="QUICK SEARCH" styleClass="label-text"/>
                <TextField fx:id="searchField"
                           promptText="Search by property name or address..."
                           styleClass="input-field"
                           maxWidth="Infinity"/>
                <ListView fx:id="propertyListView"
                          prefHeight="300"
                          styleClass="list-view"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>